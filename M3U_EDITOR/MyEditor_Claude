    def show_progress(self, text: str, maximum: int = 0):
        """Show and configure progress bar"""
        self.progress_bar.setVisible(True)
        self.progress_bar.setMaximum(maximum)
        self.progress_bar.setValue(0)
        self.status_label.setText(text)

    def hide_progress(self):
        """Hide progress bar"""
        self.progress_bar.setVisible(False)
        self.status_label.setText("")

    def update_progress(self, value: int, text: str = ""):
        """Update progress bar"""
        self.progress_bar.setValue(value)
        if text:
            self.status_label.setText(text)

    def export_selected(self):
        """Export selected group with progress tracking"""
        selected_category = self.group_combo.currentText()
        if not selected_category or selected_category not in self.categories:
            QMessageBox.warning(self, "שגיאה", "לא נבחרה קטגוריה תקפה")
            return

        directory = QFileDialog.getExistingDirectory(self, "בחר תיקיית יעד")
        if directory:
            self.show_progress(f"מייצא קטגוריה: {selected_category}", 1)

            try:
                self.export_group_enhanced(selected_category, directory)
                self.update_progress(1, "הייצוא הושלם בהצלחה!")

                QMessageBox.information(self, "הצלחה",
                    f"הקטגוריה '{selected_category}' יוצאה בהצלחה!")

            except Exception as e:
                QMessageBox.critical(self, "שגיאה", f"שגיאה בייצוא: {str(e)}")
            finally:
                QTimer.singleShot(2000, self.hide_progress)

    def export_all(self):
        """Export all groups with progress tracking"""
        directory = QFileDialog.getExistingDirectory(self, "בחר תיקיית יעד")
        if not directory:
            return

        categories = list(self.categories.keys())
        self.show_progress("מייצא את כל הקטגוריות...", len(categories))

        exported_count = 0
        failed_count = 0

        for i, category in enumerate(categories):
            try:
                self.export_group_enhanced(category, directory)
                exported_count += 1
                self.update_progress(i + 1, f"יוצא: {category} ({i + 1}/{len(categories)})")

            except Exception as e:
                failed_count += 1
                print(f"Failed to export {category}: {e}")

            # Allow UI to update
            QApplication.processEvents()

        # Show completion message
        message = f"ייצוא הושלם!\nיוצאו בהצלחה: {exported_count}\nנכשלו: {failed_count}"
        QMessageBox.information(self, "ייצוא הושלם", message)

        QTimer.singleShot(1000, self.hide_progress)

    def export_custom(self):
        """Export with custom settings"""
        directory = QFileDialog.getExistingDirectory(self, "בחר תיקיית יעד")
        if not directory:
            return

        # Get selected categories for custom export
        selected_categories, ok = self.get_category_selection()
        if not ok or not selected_categories:
            return

        self.show_progress("מייצא עם הגדרות מותאמות אישית...", len(selected_categories))

        for i, category in enumerate(selected_categories):
            try:
                self.export_group_with_options(category, directory)
                self.update_progress(i + 1, f"מייצא: {category}")
            except Exception as e:
                QMessageBox.critical(self, "שגיאה", f"שגיאה בייצוא {category}: {str(e)}")

            QApplication.processEvents()

        QMessageBox.information(self, "הצלחה", "הייצוא המותאם אישית הושלם!")
        QTimer.singleShot(1000, self.hide_progress)

    def export_batch(self):
        """Export in batch mode with advanced options"""
        directory = QFileDialog.getExistingDirectory(self, "בחר תיקיית יעד")
        if not directory:
            return

        format_type = self.format_combo.currentText()
        naming_pattern = self.naming_combo.currentText()

        categories = list(self.categories.keys())
        self.show_progress(f"ייצוא אצווה ({format_type})...", len(categories))

        for i, category in enumerate(categories):
            try:
                filename = self.generate_filename(category, i, naming_pattern)
                full_path = os.path.join(directory, filename)

                if format_type == "JSON Format":
                    self.export_as_json(category, full_path)
                elif format_type == "XSPF Playlist":
                    self.export_as_xspf(category, full_path)
                else:
                    self.export_group_enhanced(category, directory, filename)

                self.update_progress(i + 1, f"יוצא: {filename}")

            except Exception as e:
                print(f"Batch export failed for {category}: {e}")

            QApplication.processEvents()

        QMessageBox.information(self, "ייצוא אצווה", "ייצוא האצווה הושלם בהצלחה!")
        QTimer.singleShot(1000, self.hide_progress)

    def get_category_selection(self) -> Tuple[List[str], bool]:
        """Show category selection dialog"""
        dialog = QDialog(self)
        dialog.setWindowTitle("בחר קטגוריות")
        dialog.setModal(True)

        layout = QVBoxLayout(dialog)

        # Category list with checkboxes
        scroll = QScrollArea()
        scroll_widget = QWidget()
        scroll_layout = QVBoxLayout(scroll_widget)

        checkboxes = {}
        for category in self.categories.keys():
            cb = QCheckBox(f"{category} ({len(self.categories[category])} ערוצים)")
            cb.setChecked(True)
            checkboxes[category] = cb
            scroll_layout.addWidget(cb)

        scroll.setWidget(scroll_widget)
        scroll.setWidgetResizable(True)
        scroll.setMaximumHeight(300)
        layout.addWidget(scroll)

        # Buttons
        button_layout = QHBoxLayout()
        select_all_btn = QPushButton("בחר הכל")
        deselect_all_btn = QPushButton("בטל הכל")
        ok_btn = QPushButton("אישור")
        cancel_btn = QPushButton("ביטול")

        select_all_btn.clicked.connect(lambda: [cb.setChecked(True) for cb in checkboxes.values()])
        deselect_all_btn.clicked.connect(lambda: [cb.setChecked(False) for cb in checkboxes.values()])
        ok_btn.clicked.connect(dialog.accept)
        cancel_btn.clicked.connect(dialog.reject)

        button_layout.addWidget(select_all_btn)
        button_layout.addWidget(deselect_all_btn)
        button_layout.addStretch()
        button_layout.addWidget(cancel_btn)
        button_layout.addWidget(ok_btn)

        layout.addLayout(button_layout)

        if dialog.exec_() == QDialog.Accepted:
            selected = [cat for cat, cb in checkboxes.items() if cb.isChecked()]
            return selected, True

        return [], False

    def generate_filename(self, category: str, index: int, pattern: str) -> str:
        """Generate filename based on pattern"""
        safe_category = "".join(c for c in category if c.isalnum() or c in " _-").strip()

        if pattern == "שם קטגוריה":
            return f"{safe_category}.m3u"
        elif pattern == "תאריך + שם קטגוריה":
            date_str = datetime.now().strftime("%Y%m%d")
            return f"{date_str}_{safe_category}.m3u"
        elif pattern == "מספר סידורי + שם":
            return f"{index+1:03d}_{safe_category}.m3u"
        elif pattern == "מותאם אישית" and self.custom_naming.text():
            custom = self.custom_naming.text()
            return custom.format(
                category=safe_category,
                date=datetime.now().strftime("%Y%m%d"),
                index=index+1,
                time=datetime.now().strftime("%H%M%S")
            ) + ".m3u"
        else:
            return f"{safe_category}.m3u"

    def export_group_enhanced(self, category: str, directory: str, filename: str = None):
        """Enhanced group export with modern features"""
        if filename is None:
            safe_category = "".join(c for c in category if c.isalnum() or c in " _-").strip()
            filename = f"{safe_category}.m3u"

        file_path = os.path.join(directory, filename)

        try:
            channels = self.categories[category]

            # Apply quality filter if specified
            if hasattr(self, 'quality_combo'):
                channels = self.apply_quality_filter(channels)

            # Apply sorting if specified
            if hasattr(self, 'sort_channels_cb') and self.sort_channels_cb.isChecked():
                channels = sorted(channels, key=lambda x: x.split(" (")[0].lower())

            # Apply channel limit if specified
            if hasattr(self, 'channel_limit_spin') and self.channel_limit_spin.value() > 0:
                channels = channels[:self.channel_limit_spin.value()]

            with open(file_path, 'w', encoding='utf-8') as file:
                # Write header with EPG if enabled
                if hasattr(self, 'include_epg_cb') and self.include_epg_cb.isChecked():
                    file.write('#EXTM3U x-tvg-url=""\n')
                else:
                    file.write("#EXTM3U\n")

                for channel in channels:
                    extinf_line = ""
                    if hasattr(self.parent_widget, 'extinf_lookup'):
                        extinf_line = self.parent_widget.extinf_lookup.get(channel, "")

                    if not extinf_line:
                        name = channel.split(" (")[0].strip()

                        # Add logo if enabled
                        logo_part = ""
                        if (hasattr(self, 'include_logos_cb') and
                            self.include_logos_cb.isChecked() and
                            hasattr(self.parent_widget, 'get_saved_logo')):
                            logo = get_saved_logo(name)
                            if logo:
                                logo_part = f' tvg-logo="{logo}"'

                        extinf_line = f'#EXTINF:-1{logo_part} group-title="{category}",{name}'
                    elif 'group-title="' not in extinf_line:
                        props, name = extinf_line.split(",", 1)
                        extinf_line = f'{props} group-title="{category}",{name}'

                    url = self.get_url_from_channel(channel)
                    file.write(f"{extinf_line}\n{url}\n")

        except Exception as e:
            raise Exception(f"Failed to export {category}: {e}")

    def apply_quality_filter(self, channels: List[str]) -> List[str]:
        """Apply quality filter to channels"""
        quality_filter = self.quality_combo.currentText()

        if quality_filter == "כל האיכויות":
            return channels

        filtered = []
        for channel in channels:
            quality = detect_stream_quality(channel)

            if quality_filter == "4K בלבד" and quality == "4K":
                filtered.append(channel)
            elif quality_filter == "FHD בלבד" and quality == "FHD":
                filtered.append(channel)
            elif quality_filter == "HD ומעלה" and quality in ["4K", "FHD", "HD"]:
                filtered.append(channel)
            elif quality_filter == "SD ומטה" and quality in ["SD", "Unknown"]:
                filtered.append(channel)

        return filtered

    def get_url_from_channel(self, channel: str) -> str:
        """Extract URL from channel string"""
        if hasattr(self.parent_widget, 'getUrl'):
            return self.parent_widget.getUrl(channel)

        # Fallback method
        try:
            if '(' in channel and ')' in channel:
                return channel.split(" (")[-1].rstrip(")")
        except:
            pass
        return ""

    def export_as_json(self, category: str, file_path: str):
        """Export category as JSON format"""
        channels_data = []

        for channel in self.categories[category]:
            name = channel.split(" (")[0].strip()
            url = self.get_url_from_channel(channel)
            quality = detect_stream_quality(channel)

            channel_data = {
                "name": name,
                "url": url,
                "quality": quality,
                "category": category
            }

            # Add logo if available
            if hasattr(self.parent_widget, 'get_saved_logo'):
                logo = get_saved_logo(name)
                if logo:
                    channel_data["logo"] = logo

            channels_data.append(channel_data)

        export_data = {
            "category": category,
            "channel_count": len(channels_data),
            "export_date": datetime.now().isoformat(),
            "channels": channels_data
        }

        with open(file_path.replace('.m3u', '.json'), 'w', encoding='utf-8') as file:
            json.dump(export_data, file, indent=2, ensure_ascii=False)

    def export_as_xspf(self, category: str, file_path: str):
        """Export category as XSPF playlist format"""
        xspf_content = ['<?xml version="1.0" encoding="UTF-8"?>']
        xspf_content.append('<playlist version="1" xmlns="http://xspf.org/ns/0/">')
        xspf_content.append(f'  <title>{category}</title>')
        xspf_content.append('  <trackList>')

        for channel in self.categories[category]:
            name = channel.split(" (")[0].strip()
            url = self.get_url_from_channel(channel)

            xspf_content.append('    <track>')
            xspf_content.append(f'      <title>{name}</title>')
            xspf_content.append(f'      <location>{url}</location>')

            # Add logo if available
            if hasattr(self.parent_widget, 'get_saved_logo'):
                logo = get_saved_logo(name)
                if logo:
                    xspf_content.append(f'      <image>{logo}</image>')

            xspf_content.append('    </track>')

        xspf_content.append('  </trackList>')
        xspf_content.append('</playlist>')

        with open(file_path.replace('.m3u', '.xspf'), 'w', encoding='utf-8') as file:
            file.write('\n'.join(xspf_content))

    def export_group_with_options(self, category: str, directory: str):
        """Export group with current advanced options"""
        self.export_group_enhanced(category, directory)