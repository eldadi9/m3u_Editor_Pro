class CategoryTranslateThread(QThread):
    """Enhanced translation thread with better error handling and progress tracking"""

    progress = pyqtSignal(int, str, float)  # Added percentage
    finished = pyqtSignal(dict, dict, str)
    error = pyqtSignal(str)

    def __init__(self, categories: Dict[str, List[str]], mode: str):
        super().__init__()
        self.categories = categories
        self.mode = mode
        self.mutex = QMutex()
        self._stop_requested = False

    def stop(self):
        """Stop translation gracefully"""
        with QMutexLocker(self.mutex):
            self._stop_requested = True

    def run(self):
        """Enhanced translation with better error handling"""
        try:
            updated_categories = {}
            category_mapping = {}

            # Initialize translators with retry logic
            try:
                translator_en = GoogleTranslator(source='auto', target='en')
                translator_he = GoogleTranslator(source='auto', target='iw')
            except Exception as e:
                self.error.emit(f"Failed to initialize translators: {e}")
                return

            total = len(self.categories)
            processed = 0

            for old_name, channels in self.categories.items():
                with QMutexLocker(self.mutex):
                    if self._stop_requested:
                        return

                try:
                    translated_name = self._translate_category_name(
                        old_name, translator_en, translator_he
                    )

                    updated_categories[translated_name] = channels
                    category_mapping[old_name] = translated_name

                    processed += 1
                    percentage = (processed / total) * 100
                    self.progress.emit(processed, old_name, percentage)

                except Exception as e:
                    # Fallback to original name on translation error
                    updated_categories[old_name] = channels
                    category_mapping[old_name] = old_name
                    processed += 1
                    percentage = (processed / total) * 100
                    self.progress.emit(processed, f"Failed: {old_name}", percentage)

            self.finished.emit(updated_categories, category_mapping, self.mode)

        except Exception as e:
            self.error.emit(f"Translation thread error: {e}")

    def _translate_category_name(self, name: str, translator_en, translator_he) -> str:
        """Enhanced category name translation with caching"""
        parts = [p.strip() for p in name.split('|')]
        eng = next((self._clean_text(p) for p in parts if self._is_english(p)), None)
        heb = next((self._clean_text(p) for p in parts if self._is_hebrew(p)), None)

        if self.mode == "English Only":
            return eng or self._safe_translate(translator_en, parts[0])
        elif self.mode == "Hebrew Only":
            return heb or self._safe_translate(translator_he, parts[0])
        else:  # Both languages
            if not eng:
                eng = self._safe_translate(translator_en, parts[0])
            if not heb:
                heb = self._safe_translate(translator_he, parts[0])
            return f"{eng} | {heb}"

    @staticmethod
    def _clean_text(text: str) -> str:
        """Clean text from unwanted characters"""
        return re.sub(r'[\r\n\t\x00-\x1F]', '', text).strip()

    @staticmethod
    def _is_hebrew(text: str) -> bool:
        """Check if text contains Hebrew characters"""
        return any('\u0590' <= c <= '\u05EA' for c in text)

    @staticmethod
    def _is_english(text: str) -> bool:
        """Check if text is English"""
        return all(ord(c) < 128 for c in text if c.isalpha())

    def _safe_translate(self, translator, text: str, max_retries: int = 3) -> str:
        """Safe translation with retry logic"""
        for attempt in range(max_retries):
            try:
                time.sleep(0.1 * attempt)  # Progressive delay
                return self._clean_text(translator.translate(text))
            except Exception as e:
                if attempt == max_retries - 1:
                    print(f"Translation failed after {max_retries} attempts: {e}")
                    return text
        return text

class ChannelTranslateThread(QThread):
    """Enhanced channel translation thread with batch processing"""

    progress = pyqtSignal(int, str, float)
    finished = pyqtSignal(dict, dict)
    error = pyqtSignal(str)

    # Class-level cache with size limit
    _cache = {}
    _cache_max_size = 1000

    def __init__(self, categories_dict: Dict[str, List[str]]):
        super().__init__()
        self.categories = categories_dict
        self.mutex = QMutex()
        self._stop_requested = False

    def stop(self):
        """Stop translation gracefully"""
        with QMutexLocker(self.mutex):
            self._stop_requested = True

    def run(self):
        """Enhanced translation with batch processing and caching"""
        try:
            # Initialize translator
            try:
                translator = GoogleTranslator(source='auto', target='en')
            except Exception as e:
                self.error.emit(f"Failed to initialize translator: {e}")
                return

            # Collect all unique names to translate
            to_translate = set()
            for lst in self.categories.values():
                for entry in lst:
                    name = entry.split(" (")[0].strip()
                    if name and not self._is_english(name):
                        to_translate.add(name)

            # Remove cached items
            todo = [n for n in to_translate if n not in self._cache]

            # Batch translate new items
            self._batch_translate(translator, todo)

            # Apply translations
            new_categories = {}
            mapping = {}
            count = 0
            total = sum(len(v) for v in self.categories.values())

            for cat, lst in self.categories.items():
                with QMutexLocker(self.mutex):
                    if self._stop_requested:
                        return

                new_list = []
                for entry in lst:
                    translated_entry = self._translate_entry(entry)
                    new_list.append(translated_entry)
                    mapping[entry] = translated_entry

                    count += 1
                    percentage = (count / total) * 100
                    name = entry.split(" (")[0].strip()
                    self.progress.emit(count, name, percentage)

                new_categories[cat] = new_list

            self.finished.emit(new_categories, mapping)

        except Exception as e:
            self.error.emit(f"Channel translation error: {e}")

    def _batch_translate(self, translator, names: List[str]):
        """Translate names in batches for better performance"""
        batch_size = min(BATCH_SIZE, 30)  # Smaller batches for stability

        for i in range(0, len(names), batch_size):
            with QMutexLocker(self.mutex):
                if self._stop_requested:
                    return

            batch = names[i:i+batch_size]
            try:
                results = translator.translate_batch(batch)
                for orig, trans in zip(batch, results):
                    self._add_to_cache(orig, trans or orig)
            except Exception as e:
                # Fallback to individual translation
                print(f"Batch translation failed, falling back: {e}")
                for name in batch:
                    try:
                        result = translator.translate(name)
                        self._add_to_cache(name, result or name)
                    except:
                        self._add_to_cache(name, name)

    def _translate_entry(self, entry: str) -> str:
        """Translate a single entry with caching"""
        if "(" in entry and entry.endswith(")"):
            name, rest = entry.split(" (", 1)
            url = rest[:-1]
        else:
            name, url = entry, ""

        if self._is_english(name):
            new_name = name
        else:
            new_name = self._cache.get(name, name)

        return f"{new_name} ({url})" if url else new_name

    @classmethod
    def _add_to_cache(cls, key: str, value: str):
        """Add item to cache with size limit"""
        if len(cls._cache) >= cls._cache_max_size:
            # Remove oldest 10% of cache
            items_to_remove = list(cls._cache.keys())[:cls._cache_max_size // 10]
            for item in items_to_remove:
                cls._cache.pop(item, None)

        cls._cache[key] = value

    @staticmethod
    def _is_english(txt: str) -> bool:
        """Check if text is English"""
        return all(ord(c) < 128 for c in txt if c.isalpha())

