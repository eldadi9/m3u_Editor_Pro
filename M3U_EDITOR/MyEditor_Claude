class AnimationManager:
    """Handle UI animations and transitions"""

    @staticmethod
    def fade_in(widget, duration=300):
        """Fade in animation for widgets"""
        animation = QPropertyAnimation(widget, b"windowOpacity")
        animation.setDuration(duration)
        animation.setStartValue(0.0)
        animation.setEndValue(1.0)
        animation.setEasingCurve(QEasingCurve.OutCubic)
        animation.start()
        return animation

    @staticmethod
    def slide_in(widget, direction='left', duration=300):
        """Slide in animation for widgets"""
        geometry = widget.geometry()

        if direction == 'left':
            start_pos = QRect(-geometry.width(), geometry.y(), geometry.width(), geometry.height())
        elif direction == 'right':
            start_pos = QRect(geometry.width(), geometry.y(), geometry.width(), geometry.height())
        elif direction == 'up':
            start_pos = QRect(geometry.x(), -geometry.height(), geometry.width(), geometry.height())
        else:  # down
            start_pos = QRect(geometry.x(), geometry.height(), geometry.width(), geometry.height())

        widget.setGeometry(start_pos)

        animation = QPropertyAnimation(widget, b"geometry")
        animation.setDuration(duration)
        animation.setStartValue(start_pos)
        animation.setEndValue(geometry)
        animation.setEasingCurve(QEasingCurve.OutCubic)
        animation.start()
        return animation

class ChannelWidget(QWidget):
    """Enhanced channel widget with modern styling and animations"""

    def __init__(self, name: str, quality: str, logo_url: str = None, parent=None):
        super().__init__(parent)
        self.name = name
        self.quality = quality
        self.logo_url = logo_url
        self.setup_ui()
        self.setup_animations()

    def setup_ui(self):
        """Setup the UI with modern design"""
        layout = QHBoxLayout(self)
        layout.setContentsMargins(12, 8, 12, 8)
        layout.setSpacing(12)

        # Logo container
        self.logo_label = QLabel()
        self.logo_label.setFixedSize(40, 40)
        self.logo_label.setScaledContents(True)
        self.logo_label.setStyleSheet("""
            QLabel {
                border: 2px solid #e9ecef;
                border-radius: 20px;
                background: white;
            }
        """)

        # Load logo if available
        if self.logo_url:
            self.load_logo_async()
        else:
            self.logo_label.setText("📺")
            self.logo_label.setAlignment(Qt.AlignCenter)

        layout.addWidget(self.logo_label)

        # Channel info container
        info_widget = QWidget()
        info_layout = QVBoxLayout(info_widget)
        info_layout.setContentsMargins(0, 0, 0, 0)
        info_layout.setSpacing(4)

        # Channel name
        self.name_label = QLabel(self.name)
        self.name_label.setStyleSheet("""
            QLabel {
                font-size: 16px;
                font-weight: bold;
                color: #2c3e50;
            }
        """)
        info_layout.addWidget(self.name_label)

        # Quality badge
        self.quality_label = QLabel(self.quality)
        self.quality_label.setFixedSize(60, 24)
        self.quality_label.setAlignment(Qt.AlignCenter)
        quality_styles = {
            '4K': 'background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #e74c3c, stop:1 #c0392b); color: white;',
            'FHD': 'background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #3498db, stop:1 #2980b9); color: white;',
            'HD': 'background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #f39c12, stop:1 #e67e22); color: white;',
            'SD': 'background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #95a5a6, stop:1 #7f8c8d); color: white;',
            'Unknown': 'background: #bdc3c7; color: #2c3e50;'
        }

        style = quality_styles.get(self.quality, quality_styles['Unknown'])
        self.quality_label.setStyleSheet(f"""
            QLabel {{
                {style}
                border-radius: 12px;
                font-size: 12px;
                font-weight: bold;
                padding: 2px;
            }}
        """)
        info_layout.addWidget(self.quality_label)

        layout.addWidget(info_widget)
        layout.addStretch()

        # Modern container styling
        self.setStyleSheet("""
            ChannelWidget {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #ffffff, stop:1 #f8f9fa);
                border: 1px solid #e9ecef;
                border-radius: 12px;
                margin: 2px;
            }
            ChannelWidget:hover {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #e3f2fd, stop:1 #bbdefb);
                border: 2px solid #007acc;
                transform: translateY(-2px);
            }
        """)

    def setup_animations(self):
        """Setup hover animations"""
        self.setAttribute(Qt.WA_Hover, True)

    def load_logo_async(self):
        """Load logo asynchronously to avoid blocking UI"""
        def load_logo():
            try:
                response = requests.get(self.logo_url, timeout=5)
                if response.status_code == 200:
                    pixmap = QPixmap()
                    pixmap.loadFromData(response.content)
                    self.logo_label.setPixmap(pixmap)
            except:
                self.logo_label.setText("📺")
                self.logo_label.setAlignment(Qt.AlignCenter)

        threading.Thread(target=load_logo, daemon=True).start()

    def enterEvent(self, event):
        """Handle mouse enter with animation"""
        self.setStyleSheet(self.styleSheet() + """
            ChannelWidget {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);
            }
        """)
        super().enterEvent(event)

    def leaveEvent(self, event):
        """Handle mouse leave"""
        self.setStyleSheet(self.styleSheet().replace(
            "transform: translateY(-2px);", ""
        ).replace(
            "box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);", ""
        ))
        super().leaveEvent(event)

def create_channel_widget(name: str, quality: str, logo_url: str = None) -> ChannelWidget:
    """Factory function for creating enhanced channel widgets"""
    return ChannelWidget(name, quality, logo_url)

class LoadingWidget(QWidget):
    """Modern loading widget with animations"""

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setup_ui()
        self.start_animation()

    def setup_ui(self):
        """Setup loading UI"""
        layout = QVBoxLayout(self)
        layout.setAlignment(Qt.AlignCenter)

        # Loading animation
        self.movie = QMovie(":/icons/loading.gif")  # You'll need to add this resource
        self.loading_label = QLabel()
        self.loading_label.setMovie(self.movie)
        self.loading_label.setAlignment(Qt.AlignCenter)

        # Loading text
        self.text_label = QLabel("Loading...")
        self.text_label.setAlignment(Qt.AlignCenter)
        self.text_label.setStyleSheet("""
            QLabel {
                font-size: 18px;
                font-weight: bold;
                color: #007acc;
                margin: 12px;
            }
        """)

        layout.addWidget(self.loading_label)
        layout.addWidget(self.text_label)

        self.setStyleSheet("""
            LoadingWidget {
                background: rgba(255, 255, 255, 0.95);
                border-radius: 12px;
            }
        """)

    def start_animation(self):
        """Start loading animation"""
        if hasattr(self, 'movie'):
            self.movie.start()

    def stop_animation(self):
        """Stop loading animation"""
        if hasattr(self, 'movie'):
            self.movie.stop()

    def set_text(self, text: str):
        """Update loading text"""
        self.text_label.setText(text)
