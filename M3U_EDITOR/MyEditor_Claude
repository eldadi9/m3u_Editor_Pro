@lru_cache(maxsize=1000)
def cached_detect_stream_quality(entry: str) -> str:
    """Cached version of stream quality detection for better performance"""
    e = entry.lower()
    if '4k' in e or '2160' in e:
        return '4K'
    if '1080' in e or 'fhd' in e:
        return 'FHD'
    if '720' in e or re.search(r'\bhd\b', e):
        return 'HD'
    if '480' in e or re.search(r'\bsd\b', e):
        return 'SD'
    return 'Unknown'

def detect_stream_quality(entry: str) -> str:
    """Enhanced stream quality detection with caching"""
    return cached_detect_stream_quality(entry)

